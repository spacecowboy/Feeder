import { BatchTranslator, TranslatorBacking } from "./translator.js";

class FeederBacking extends TranslatorBacking {
    async loadModelRegistery() {
        return this.options.modelRegistry;
    }

    async loadTranslationModel({ from, to }) {
        console.log("FeederBacking.loadTranslationModel: loading model " + from + "->" + to);
        const entries = (await this.registry).filter((model) => model.from === from && model.to === to);
        if (!entries.length) {
            throw new Error(`No app model for ${from} to ${to}`);
        }

        const files = entries[0].files;
        console.log("FeederBacking.loadTranslationModel: files keys=" + Object.keys(files).join(","));

        // Helper to fetch a file via XHR since WebView fetch() doesn't support file://
        const fetchFile = (url) => new Promise((resolve, reject) => {
            const xhr = new XMLHttpRequest();
            xhr.open('GET', url, true);
            xhr.responseType = 'arraybuffer';
            xhr.onload = () => {
                if (xhr.status === 200 || xhr.status === 0) {
                    resolve(xhr.response);
                } else {
                    reject(new Error(`XHR failed: status=${xhr.status}`));
                }
            };
            xhr.onerror = () => reject(new Error(`XHR network error for ${url}`));
            xhr.send();
        });

        const buffers = Object.fromEntries(await Promise.all(Object.entries(files).map(async ([part, file]) => {
            if (!file || !file.url) {
                console.log("FeederBacking.loadTranslationModel: " + part + " has no url, skipping");
                return [part, null];
            }
            console.log("FeederBacking.loadTranslationModel: fetching " + part + " from " + file.url);
            const buffer = await fetchFile(file.url);
            console.log("FeederBacking.loadTranslationModel: fetched " + part + " (" + buffer.byteLength + " bytes)");
            return [part, buffer];
        })));
        console.log("FeederBacking.loadTranslationModel: got " + Object.keys(buffers).length + " buffers");

        const vocabs = buffers.vocab ? [buffers.vocab] : [buffers.srcvocab, buffers.trgvocab].filter(Boolean);
        if (!vocabs.length) {
            throw new Error(`No vocabulary file for ${from} to ${to}`);
        }

        const config = {};
        if (files.model.name.endsWith("intgemm8.bin")) {
            config["gemm-precision"] = "int8shiftAll";
        }
        if (files.qualityModel) {
            config["skip-cost"] = false;
        }
        if (files.config) {
            Object.assign(config, files.config);
        }

        return {
            model: buffers.model,
            shortlist: buffers.lex,
            vocabs,
            qualityModel: buffers.qualityModel,
            config,
        };
    }
}

let translator = null;

window.FeederBergamot = {
    initialize(modelRegistry) {
        console.log("FeederBergamot.initialize called, modelRegistry entries:", modelRegistry.length);
        if (translator) {
            console.log("FeederBergamot.initialize: deleting old translator");
            translator.delete();
        }
        const options = {
            modelRegistry,
            pivotLanguage: "en",
            workers: 1,
            batchSize: 4,
            cacheSize: 16384,
            downloadTimeout: 0,
            useNativeIntGemm: false,
            onerror: (error) => {
                const msg = error && error.message ? error.message :
                    (error && error.target && error.target.message ? error.target.message :
                    String(error));
                console.error("FeederBergamot onerror:", msg);
                window.AndroidBergamot.onLog(msg);
            },
        };
        console.log("FeederBergamot.initialize: creating BatchTranslator");
        translator = new BatchTranslator(options, new FeederBacking(options));
        console.log("FeederBergamot.initialize: done");
    },

    async translate(id, from, to, text, html) {
        try {
            console.log("FeederBergamot.translate: id=" + id + " from=" + from + " to=" + to + " textLen=" + text.length + " html=" + html);
            if (!translator) {
                throw new Error("Bergamot translator is not initialized");
            }
            const response = await translator.translate({
                from,
                to,
                text,
                html,
                qualityScores: false,
            });
            console.log("FeederBergamot.translate SUCCESS: id=" + id);
            window.AndroidBergamot.onTranslationSuccess(id, response.target.text);
        } catch (error) {
            console.error("FeederBergamot.translate ERROR: id=" + id + " " + String(error && error.message ? error.message : error));
            window.AndroidBergamot.onTranslationError(id, String(error && error.message ? error.message : error));
        }
    },

    async translateBatch(id, from, to, texts, html) {
        try {
            console.log("FeederBergamot.translateBatch: id=" + id + " from=" + from + " to=" + to + " texts.length=" + texts.length + " html=" + html);
            if (!translator) {
                throw new Error("Bergamot translator is not initialized");
            }
            const responses = await Promise.all(texts.map((text) => translator.translate({
                from,
                to,
                text,
                html,
                qualityScores: false,
            })));
            console.log("FeederBergamot.translateBatch SUCCESS: id=" + id + " responses.length=" + responses.length);
            window.AndroidBergamot.onTranslationBatchSuccess(id, JSON.stringify(responses.map((response) => response.target.text)));
        } catch (error) {
            console.error("FeederBergamot.translateBatch ERROR: id=" + id + " " + String(error && error.message ? error.message : error));
            window.AndroidBergamot.onTranslationError(id, String(error && error.message ? error.message : error));
        }
    },
};

window.AndroidBergamot.onReady();
